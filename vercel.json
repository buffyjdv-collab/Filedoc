{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm install",
  "regions": ["iad1"],
  "env": {
    "DATABASE_URL": {
      "description": "NeonDB pooled connection URL — e.g. postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/filedoc?sslmode=require"
    },
    "DIRECT_URL": {
      "description": "NeonDB direct connection URL for migrations — e.g. postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/filedoc?sslmode=require"
    }
  }
}
