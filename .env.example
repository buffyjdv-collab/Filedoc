# Filedoc - Environment Variables
#
# LOCAL DEVELOPMENT (SQLite):
DATABASE_URL=file:./db/custom.db

# PRODUCTION (NeonDB PostgreSQL):
# 1. Create a database at https://neon.tech
# 2. Copy the connection pool URL and direct URL
# 3. Set these in Vercel dashboard → Settings → Environment Variables
#
# DATABASE_URL=postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/filedoc?sslmode=require
# DIRECT_URL=postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/filedoc?sslmode=require
