# NeonDB PostgreSQL - Connection Strings
# Get these from your NeonDB dashboard: https://console.neon.tech
#
# DATABASE_URL = Connection pooler URL (used by the app at runtime)
# DIRECT_URL   = Direct connection URL (used by Prisma for migrations)
#
# Example:
#   DATABASE_URL=postgres://filedoc:password@ep-cool-name-12345.us-east-2.aws.neon.tech/filedoc?sslmode=require
#   DIRECT_URL=postgres://filedoc:password@ep-cool-name-12345.us-east-2.aws.neon.tech/filedoc?sslmode=require

DATABASE_URL=
DIRECT_URL=
