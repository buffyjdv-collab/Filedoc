# ============================================================
# Filedoc — Environment Variables
# ============================================================
#
# 1. Create a NeonDB database at https://console.neon.tech
# 2. Copy the connection strings from your project dashboard
# 3. Set these as Vercel environment variables:
#    vercel env add DATABASE_URL
#    vercel env add DIRECT_URL
#
# ============================================================

# NeonDB pooled connection (used by the app at runtime via Prisma)
DATABASE_URL=postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/filedoc?sslmode=require

# NeonDB direct connection (used by Prisma for migrations)
DIRECT_URL=postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/filedoc?sslmode=require
